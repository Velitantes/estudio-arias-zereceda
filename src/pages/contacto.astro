---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contáctenos | Arias & Zereceda" currentPage="/contacto">
  <main class="flex-grow flex flex-col pt-section-gap pb-section-gap relative">
    <!-- Abstract Background Element -->
    <div class="absolute inset-0 bg-hero-pattern opacity-10 pointer-events-none"></div>
    
    <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop w-full relative z-10 flex flex-col gap-16">
      
      <!-- Page Header -->
      <div class="flex flex-col gap-4 max-w-2xl">
        <span class="font-subheading-caps text-subheading-caps text-primary uppercase tracking-widest">Atención Personalizada</span>
        <h1 class="font-display-lg text-headline-lg-mobile md:text-display-lg text-on-surface">Estamos aquí para escucharlo.</h1>
        <p class="font-body-lg text-body-lg text-on-surface-variant">Concertemos una reunión para evaluar su caso con la rigurosidad y confidencialidad que nos caracteriza.</p>
      </div>

      <!-- Content Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter lg:gap-24 relative">
        <!-- Center Divider Line (Desktop) -->
        <div class="hidden lg:block absolute left-1/2 top-0 bottom-0 w-px bg-outline-variant opacity-30 transform -translate-x-1/2"></div>
        
        <!-- Left Column: Form -->
        <div class="lg:col-span-6 flex flex-col gap-8 pr-0 lg:pr-8">
          <form class="flex flex-col gap-8" action="#" method="POST" id="contact-form">
            <div class="flex flex-col gap-2 relative">
              <label for="nombre" class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-widest">Nombre Completo</label>
              <input type="text" id="nombre" name="nombre" placeholder="Ej. Juan Pérez" class="w-full bg-transparent border-0 border-b border-outline-variant opacity-80 focus:border-primary focus:ring-0 px-0 py-2 font-body-md text-on-surface transition-colors placeholder:text-outline/50 outline-none" required />
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div class="flex flex-col gap-2 relative">
                <label for="email" class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-widest">Correo Electrónico</label>
                <input type="email" id="email" name="email" placeholder="juan@ejemplo.com" class="w-full bg-transparent border-0 border-b border-outline-variant opacity-80 focus:border-primary focus:ring-0 px-0 py-2 font-body-md text-on-surface transition-colors placeholder:text-outline/50 outline-none" required />
              </div>
              <div class="flex flex-col gap-2 relative">
                <label for="telefono" class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-widest">Teléfono</label>
                <input type="tel" id="telefono" name="telefono" placeholder="+51 ..." class="w-full bg-transparent border-0 border-b border-outline-variant opacity-80 focus:border-primary focus:ring-0 px-0 py-2 font-body-md text-on-surface transition-colors placeholder:text-outline/50 outline-none" required />
              </div>
            </div>
            
            <div class="flex flex-col gap-2 relative">
              <label for="area" class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-widest">Área de Interés</label>
              <div class="relative w-full">
                <select id="area" name="area" class="w-full bg-transparent border-0 border-b border-outline-variant opacity-80 focus:border-primary focus:ring-0 px-0 py-2 font-body-md text-on-surface transition-colors appearance-none outline-none" required>
                  <option value="" disabled selected>Seleccione una opción</option>
                  <option value="penal">Derecho Penal</option>
                  <option value="familia">Derecho de Familia</option>
                  <option value="constitucional">Derecho Constitucional</option>
                  <option value="civil">Derecho Civil</option>
                  <option value="administrativo">Derecho Administrativo</option>
                  <option value="corporativo">Derecho Corporativo</option>
                </select>
                <span class="material-symbols-outlined absolute right-0 top-1/2 -translate-y-1/2 pointer-events-none text-on-surface-variant">arrow_drop_down</span>
              </div>
            </div>
            
            <div class="flex flex-col gap-2 relative">
              <label for="mensaje" class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-widest">Mensaje</label>
              <textarea id="mensaje" name="mensaje" placeholder="Describa brevemente su consulta..." rows="4" class="w-full bg-transparent border-0 border-b border-outline-variant opacity-80 focus:border-primary focus:ring-0 px-0 py-2 font-body-md text-on-surface transition-colors placeholder:text-outline/50 resize-none outline-none" required></textarea>
            </div>
            
            <button type="submit" class="self-start px-8 py-4 bg-on-surface text-surface font-subheading-caps text-subheading-caps hover:bg-primary transition-colors duration-300 rounded-none flex items-center gap-3 group mt-4">
              Enviar Mensaje
              <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
            </button>
          </form>
        </div>
        
        <!-- Right Column: Info & Locations -->
        <div class="lg:col-span-6 flex flex-col gap-12 pl-0 lg:pl-8 mt-12 lg:mt-0">
          <!-- Direct Contact -->
          <div class="flex flex-col gap-6 p-8 border border-outline-variant border-opacity-20 relative bg-surface-container-low">
            <div class="absolute top-0 left-0 w-1 h-full bg-primary"></div>
            <h3 class="font-headline-md text-headline-md text-on-surface">Contacto Directo</h3>
            <div class="flex flex-col gap-4 font-body-md text-on-surface-variant">
              <div class="flex items-center gap-4">
                <span class="material-symbols-outlined text-primary">call</span>
                <div class="flex flex-col gap-1">
                  <a href="tel:+51925295238" class="hover:text-primary transition-colors">+51 925 295 238</a>
                  <a href="tel:+51901999739" class="hover:text-primary transition-colors">+51 901 999 739</a>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <span class="material-symbols-outlined text-primary">mail</span>
                <a href="mailto:arias.zereceda.abogados@gmail.com" class="hover:text-primary transition-colors break-all">arias.zereceda.abogados@gmail.com</a>
              </div>
            </div>
            <a href="https://wa.me/51925295238" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 px-6 py-3 border border-primary text-primary font-subheading-caps text-subheading-caps hover:bg-primary hover:text-surface transition-colors rounded-none mt-2 self-start">
              <span class="material-symbols-outlined text-lg">chat</span>
              Atención vía WhatsApp
            </a>
          </div>
          
          <!-- Locations Divider -->
          <div class="flex items-center gap-4">
            <div class="h-px bg-outline-variant opacity-30 flex-grow"></div>
            <span class="font-subheading-caps text-subheading-caps text-on-surface-variant">Nuestras Sedes</span>
            <div class="h-px bg-outline-variant opacity-30 flex-grow"></div>
          </div>
          
          <!-- Locations Grid -->
          <div class="grid grid-cols-1 gap-8">
            <!-- Sede Surco -->
            <div class="flex flex-col gap-3 group">
              <h4 class="font-headline-md text-body-lg font-bold text-on-surface group-hover:text-primary transition-colors">Santiago de Surco</h4>
              <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed">
                Calle El Boulevard 161, interior 601<br/>
                Lima, Perú
              </p>
              <a href="https://www.google.com/maps/search/?api=1&query=Calle+El+Boulevard+161,+Santiago+de+Surco,+Lima" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 font-label-sm text-label-sm text-primary uppercase tracking-widest mt-2 hover:opacity-80 transition-opacity">
                Ver en Mapa <span class="material-symbols-outlined text-sm">open_in_new</span>
              </a>
            </div>
          </div>
          
          <!-- Social Media -->
          <div class="mt-4 flex flex-col gap-4">
            <span class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-widest">Síguenos en:</span>
            <div class="flex gap-4">
              <a href="https://www.tiktok.com/@arias_zereceda_abogados" target="_blank" rel="noopener noreferrer" class="w-10 h-10 border border-outline-variant opacity-50 flex items-center justify-center text-on-surface hover:border-primary hover:text-primary hover:opacity-100 transition-all rounded-none" aria-label="TikTok">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  
  <style>
    .bg-hero-pattern {
      background-image: radial-gradient(#d7c2b7 1px, transparent 1px);
      background-size: 20px 20px;
    }
  </style>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        const nombre = formData.get('nombre');
        const email = formData.get('email');
        const telefono = formData.get('telefono');
        const area = formData.get('area');
        const mensaje = formData.get('mensaje');

        const text = `Hola, mi nombre es ${nombre}.\nMi correo es: ${email}\nMi teléfono es: ${telefono}\nÁrea de interés: ${area}\n\nMensaje: ${mensaje}`;
        const whatsappUrl = `https://wa.me/51925295238?text=${encodeURIComponent(text)}`;
        
        window.open(whatsappUrl, '_blank');
        form.reset();
      });
    }
  </script>
</BaseLayout>
